generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model admins {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name       String    @db.VarChar(255)
  email      String    @db.VarChar(255)
  password   String    @db.VarChar(255)
  photo      String    @db.VarChar(255)
  token      String    @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model advertisements {
  id                        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  job_listing_ad            String    @db.VarChar(255)
  job_listing_ad_url        String?   @db.VarChar(255)
  job_listing_ad_status     String    @db.VarChar(255)
  company_listing_ad        String    @db.VarChar(255)
  company_listing_ad_url    String?   @db.VarChar(255)
  company_listing_ad_status String    @db.VarChar(255)
  created_at                DateTime? @db.Timestamp(0)
  updated_at                DateTime? @db.Timestamp(0)
}

model banners {
  id                     BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  banner_job_listing     String    @db.Text
  banner_job_detail      String    @db.Text
  banner_job_categories  String    @db.Text
  banner_company_listing String    @db.Text
  banner_company_detail  String    @db.Text
  banner_pricing         String    @db.Text
  banner_blog            String    @db.Text
  banner_post            String    @db.Text
  banner_faq             String    @db.Text
  banner_contact         String    @db.Text
  banner_terms           String    @db.Text
  banner_privacy         String    @db.Text
  banner_signup          String    @db.Text
  banner_login           String    @db.Text
  banner_forget_password String    @db.Text
  banner_company_panel   String    @db.Text
  banner_candidate_panel String    @db.Text
  created_at             DateTime? @db.Timestamp(0)
  updated_at             DateTime? @db.Timestamp(0)
}

model candidate_applications {
  id           BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  candidate_id BigInt     @db.UnsignedBigInt
  job_id       BigInt     @db.UnsignedBigInt
  cover_letter String     @db.Text
  status       String     @db.Text
  created_at   DateTime?  @db.Timestamp(0)
  updated_at   DateTime?  @db.Timestamp(0)
  candidates   candidates @relation(fields: [candidate_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "candidate_applications_candidate_id_foreign")
  jobs         jobs       @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "candidate_applications_job_id_foreign")

  @@index([candidate_id], map: "candidate_applications_candidate_id_foreign")
  @@index([job_id], map: "candidate_applications_job_id_foreign")
}

model candidate_awards {
  id           BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  candidate_id BigInt     @db.UnsignedBigInt
  title        String     @db.Text
  description  String     @db.Text
  date         String     @db.Text
  created_at   DateTime?  @db.Timestamp(0)
  updated_at   DateTime?  @db.Timestamp(0)
  candidates   candidates @relation(fields: [candidate_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "candidate_awards_candidate_id_foreign")

  @@index([candidate_id], map: "candidate_awards_candidate_id_foreign")
}

model candidate_bookmarks {
  id           BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  candidate_id BigInt     @db.UnsignedBigInt
  job_id       BigInt     @db.UnsignedBigInt
  created_at   DateTime?  @db.Timestamp(0)
  updated_at   DateTime?  @db.Timestamp(0)
  candidates   candidates @relation(fields: [candidate_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "candidate_bookmarks_candidate_id_foreign")
  jobs         jobs       @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "candidate_bookmarks_job_id_foreign")

  @@index([candidate_id], map: "candidate_bookmarks_candidate_id_foreign")
  @@index([job_id], map: "candidate_bookmarks_job_id_foreign")
}

model candidate_education {
  id           BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  candidate_id BigInt     @db.UnsignedBigInt
  level        String     @db.Text
  institute    String     @db.Text
  degree       String     @db.Text
  passing_year String     @db.Text
  created_at   DateTime?  @db.Timestamp(0)
  updated_at   DateTime?  @db.Timestamp(0)
  candidates   candidates @relation(fields: [candidate_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "candidate_education_candidate_id_foreign")

  @@index([candidate_id], map: "candidate_education_candidate_id_foreign")
}

model candidate_experiences {
  id           BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  candidate_id BigInt     @db.UnsignedBigInt
  company      String     @db.Text
  designation  String     @db.Text
  start_date   String     @db.Text
  end_date     String     @db.Text
  created_at   DateTime?  @db.Timestamp(0)
  updated_at   DateTime?  @db.Timestamp(0)
  candidates   candidates @relation(fields: [candidate_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "candidate_experiences_candidate_id_foreign")

  @@index([candidate_id], map: "candidate_experiences_candidate_id_foreign")
}

model candidate_resumes {
  id           BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  candidate_id BigInt     @db.UnsignedBigInt
  name         String     @db.Text
  file         String     @db.Text
  created_at   DateTime?  @db.Timestamp(0)
  updated_at   DateTime?  @db.Timestamp(0)
  candidates   candidates @relation(fields: [candidate_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "candidate_resumes_candidate_id_foreign")

  @@index([candidate_id], map: "candidate_resumes_candidate_id_foreign")
}

model candidate_skills {
  id           BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  candidate_id BigInt     @db.UnsignedBigInt
  name         String     @db.Text
  percentage   String     @db.Text
  created_at   DateTime?  @db.Timestamp(0)
  updated_at   DateTime?  @db.Timestamp(0)
  candidates   candidates @relation(fields: [candidate_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "candidate_skills_candidate_id_foreign")

  @@index([candidate_id], map: "candidate_skills_candidate_id_foreign")
}

model candidates {
  id                     BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  name                   String                   @db.VarChar(255)
  designation            String?                  @db.VarChar(255)
  username               String                   @db.VarChar(255)
  email                  String                   @db.VarChar(255)
  password               String                   @db.VarChar(255)
  token                  String?                  @db.VarChar(255)
  photo                  String?                  @db.VarChar(255)
  biography              String?                  @db.Text
  phone                  String?                  @db.VarChar(255)
  country                String?                  @db.VarChar(255)
  address                String?                  @db.VarChar(255)
  state                  String?                  @db.VarChar(255)
  city                   String?                  @db.VarChar(255)
  zip_code               String?                  @db.VarChar(255)
  gender                 String?                  @db.VarChar(255)
  marital_status         String?                  @db.VarChar(255)
  date_of_birth          String?                  @db.VarChar(255)
  website                String?                  @db.VarChar(255)
  status                 Int                      @db.TinyInt
  created_at             DateTime?                @db.Timestamp(0)
  updated_at             DateTime?                @db.Timestamp(0)
  candidate_applications candidate_applications[]
  candidate_awards       candidate_awards[]
  candidate_bookmarks    candidate_bookmarks[]
  candidate_education    candidate_education[]
  candidate_experiences  candidate_experiences[]
  candidate_resumes      candidate_resumes[]
  candidate_skills       candidate_skills[]
}

model companies {
  id                  BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  company_name        String              @db.VarChar(255)
  person_name         String              @db.VarChar(255)
  username            String              @db.VarChar(255)
  email               String              @db.VarChar(255)
  password            String              @db.VarChar(255)
  token               String?             @db.VarChar(255)
  logo                String?             @db.VarChar(255)
  phone               String?             @db.VarChar(255)
  address             String?             @db.VarChar(255)
  company_location_id BigInt?             @db.UnsignedBigInt
  company_size_id     BigInt?             @db.UnsignedBigInt
  founded_on          String?             @db.VarChar(255)
  website             String?             @db.VarChar(255)
  description         String?             @db.Text
  oh_mon              String?             @db.VarChar(255)
  oh_tue              String?             @db.VarChar(255)
  oh_wed              String?             @db.VarChar(255)
  oh_thu              String?             @db.VarChar(255)
  oh_fri              String?             @db.VarChar(255)
  oh_sat              String?             @db.VarChar(255)
  oh_sun              String?             @db.VarChar(255)
  map_code            String?             @db.Text
  facebook            String?             @db.Text
  twitter             String?             @db.Text
  linkedin            String?             @db.Text
  instagram           String?             @db.Text
  status              Int                 @db.TinyInt
  company_industry_id BigInt?             @db.UnsignedBigInt
  created_at          DateTime?           @db.Timestamp(0)
  updated_at          DateTime?           @db.Timestamp(0)
  company_industries  company_industries? @relation(fields: [company_industry_id], references: [id], onUpdate: NoAction, map: "companies_company_industry_id_foreign")
  company_locations   company_locations?  @relation(fields: [company_location_id], references: [id], onUpdate: NoAction, map: "companies_company_location_id_foreign")
  company_sizes       company_sizes?      @relation(fields: [company_size_id], references: [id], onUpdate: NoAction, map: "companies_company_size_id_foreign")
  company_photos      company_photos[]
  company_videos      company_videos[]
  jobs                jobs[]
  orders              orders[]

  @@index([company_industry_id], map: "companies_company_industry_id_foreign")
  @@index([company_location_id], map: "companies_company_location_id_foreign")
  @@index([company_size_id], map: "companies_company_size_id_foreign")
}

model company_industries {
  id         BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  name       String      @db.VarChar(255)
  created_at DateTime?   @db.Timestamp(0)
  updated_at DateTime?   @db.Timestamp(0)
  companies  companies[]
}

model company_locations {
  id         BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  name       String      @db.VarChar(255)
  created_at DateTime?   @db.Timestamp(0)
  updated_at DateTime?   @db.Timestamp(0)
  companies  companies[]
}

model company_photos {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  company_id BigInt    @db.UnsignedBigInt
  photo      String    @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  companies  companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "company_photos_company_id_foreign")

  @@index([company_id], map: "company_photos_company_id_foreign")
}

model company_sizes {
  id         BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  name       String      @db.VarChar(255)
  created_at DateTime?   @db.Timestamp(0)
  updated_at DateTime?   @db.Timestamp(0)
  companies  companies[]
}

model company_videos {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  company_id BigInt    @db.UnsignedBigInt
  video_id   String    @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  companies  companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "company_videos_company_id_foreign")

  @@index([company_id], map: "company_videos_company_id_foreign")
}

model failed_jobs {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  uuid       String   @unique(map: "failed_jobs_uuid_unique") @db.VarChar(255)
  connection String   @db.Text
  queue      String   @db.Text
  payload    String   @db.LongText
  exception  String   @db.LongText
  failed_at  DateTime @default(now()) @db.Timestamp(0)
}

model faqs {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  question   String    @db.Text
  answer     String    @db.Text
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model job_categories {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
