  updated_at DateTime? @db.Timestamp(0)
  jobs       jobs[]
}

model jobs {
  id                     BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  company_id             BigInt                   @db.UnsignedBigInt
  title                  String                   @db.Text
  description            String                   @db.Text
  responsibility         String?                  @db.Text
  skill                  String?                  @db.Text
  education              String?                  @db.Text
  benefit                String?                  @db.Text
  deadline               String                   @db.Text
  vacancy                Int
  job_category_id        BigInt                   @db.UnsignedBigInt
  job_location_id        BigInt                   @db.UnsignedBigInt
  job_type_id            BigInt                   @db.UnsignedBigInt
  job_experience_id      BigInt                   @db.UnsignedBigInt
  job_gender_id          BigInt                   @db.UnsignedBigInt
  job_salary_range_id    BigInt                   @db.UnsignedBigInt
  map_code               String?                  @db.Text
  is_featured            Int                      @db.TinyInt
  is_urgent              Int                      @db.TinyInt
  created_at             DateTime?                @db.Timestamp(0)
  updated_at             DateTime?                @db.Timestamp(0)
  candidate_applications candidate_applications[]
  candidate_bookmarks    candidate_bookmarks[]
  companies              companies                @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "jobs_company_id_foreign")
  job_categories         job_categories           @relation(fields: [job_category_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "jobs_job_category_id_foreign")
  job_experiences        job_experiences          @relation(fields: [job_experience_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "jobs_job_experience_id_foreign")
  job_genders            job_genders              @relation(fields: [job_gender_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "jobs_job_gender_id_foreign")
  job_locations          job_locations            @relation(fields: [job_location_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "jobs_job_location_id_foreign")
  job_salary_ranges      job_salary_ranges        @relation(fields: [job_salary_range_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "jobs_job_salary_range_id_foreign")
  job_types              job_types                @relation(fields: [job_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "jobs_job_type_id_foreign")

  @@index([company_id], map: "jobs_company_id_foreign")
  @@index([job_category_id], map: "jobs_job_category_id_foreign")
  @@index([job_experience_id], map: "jobs_job_experience_id_foreign")
  @@index([job_gender_id], map: "jobs_job_gender_id_foreign")
  @@index([job_location_id], map: "jobs_job_location_id_foreign")
  @@index([job_salary_range_id], map: "jobs_job_salary_range_id_foreign")
  @@index([job_type_id], map: "jobs_job_type_id_foreign")
}

model migrations {
  id        Int    @id @default(autoincrement()) @db.UnsignedInt
  migration String @db.VarChar(255)
  batch     Int
}

model orders {
  id               BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  company_id       BigInt    @db.UnsignedBigInt
  package_id       BigInt    @db.UnsignedBigInt
  order_no         String    @db.VarChar(255)
  paid_amount      String    @db.VarChar(255)
  payment_method   String    @db.VarChar(255)
  start_date       String    @db.VarChar(255)
  expire_date      String    @db.VarChar(255)
  currently_active Int       @db.TinyInt
  created_at       DateTime? @db.Timestamp(0)
  updated_at       DateTime? @db.Timestamp(0)
  companies        companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "orders_company_id_foreign")
  packages         packages  @relation(fields: [package_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "orders_package_id_foreign")

  @@index([company_id], map: "orders_company_id_foreign")
  @@index([package_id], map: "orders_package_id_foreign")
}

model packages {
  id                          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  package_name                String    @db.VarChar(200)
