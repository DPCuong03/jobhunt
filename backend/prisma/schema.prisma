  package_days                Int       @db.SmallInt
  package_display_time        String    @db.VarChar(100)
  total_allowed_jobs          Int       @db.TinyInt
  total_allowed_featured_jobs Int       @db.TinyInt
  total_allowed_photos        Int       @db.TinyInt
  total_allowed_videos        Int       @db.TinyInt
  created_at                  DateTime? @db.Timestamp(0)
  updated_at                  DateTime? @db.Timestamp(0)
  orders                      orders[]
}

